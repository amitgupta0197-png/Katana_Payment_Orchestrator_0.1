<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Bank credit alerts arrive by SMS on essentially every bank — most reliable
         capture source (the broadcast fires even when the app process is dead). -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <!-- Keep working across reboots + resist OEM battery killing. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Foreground keep-alive service so OEM battery management can't kill the
         notification listener (Paytm/PhonePe-for-Business pushes have no SMS). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Shizuku: shell-level input injection (taps Paytm can't reject like accessibility). -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />
    <!-- "Display over other apps" — grants background-activity-start so the accessibility
         service can launch the invisible clipboard-reader activity to capture a MASKED RRN
         (Paytm shows "209…975768"; the full value is only readable off the clipboard). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.KatanaAgent">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Bank SMS receiver. Fires even when the app process is not running. -->
        <receiver
            android:name=".SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Re-arm the background worker after reboot. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Notification listener — reads bank/UPI-app push alerts. Requires the
             user to grant Notification Access in system settings. -->
        <service
            android:name=".TxnNotificationListener"
            android:exported="false"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Keep-alive foreground service: holds the process up so the listener above
             survives Doze / OEM battery killing. -->
        <service
            android:name=".KeepAliveService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Shizuku provider — required for the Shizuku API to bind. -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!-- Invisible focused trampoline that reads a MASKED RRN off the clipboard (the
             accessibility service taps Paytm's "Copy", this reads it, then vanishes). Transparent,
             no history, kept out of Recents so it's an imperceptible ~0.3s blip. -->
        <activity
            android:name=".RrnClipboardActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:launchMode="singleInstance" />

        <!-- Screen-reader capture — scrapes the RRN off the Paytm transaction-detail
             screen (the notification omits it). Requires the user to grant Accessibility
             access in system settings. -->
        <service
            android:name=".TxnAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

    </application>
</manifest>
