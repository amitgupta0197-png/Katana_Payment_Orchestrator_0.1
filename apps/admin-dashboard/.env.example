# Postgres connection (host where docker container exposes 5432).
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=sixsenai
PG_PASSWORD=sixsenai_pg_2024_secure

# HMAC secret for the session cookie. CHANGE in any environment that isn't a
# local dev box — leaking this lets an attacker forge sessions for any persona.
SESSION_SECRET=dev-session-secret-do-not-use-in-prod

# Demo password accepted by /api/auth/login for seeded users.
# Remove from production deployments; replace with bcrypt against users.password_hash.
DEMO_PASSWORD=demo
